---
// src/components/BentoGrid.astro
interface Props {
  items: any[];
  type: 'campus' | 'zone' | 'space';
  baseUrl: string;
}
const { items, type, baseUrl } = Astro.props;

const icons = { campus: "🏢", zone: "🗺️", space: "📍" };
---
<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">
  {items.map((item) => {
    // Detecta dinámicamente el campo del responsable según tu base de datos
    const responsible = item.responsible || item.responsible_name || item.user_email || item.created_by || null;

    return (
      <div class="relative group bg-white border border-slate-200 rounded-3xl shadow-sm hover:shadow-md hover:scale-[1.02] transition-all overflow-hidden aspect-square flex flex-col items-center justify-center text-center p-6">
        
        <!-- Botón de edición flotante estilo iOS -->
        <button 
          onclick={`event.preventDefault(); event.stopPropagation(); openEditModal('${type}', ${item.id}, '${item.name}', '${item.description || item.address || ''}', '${responsible || ''}')`}
          class="absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity bg-slate-100 hover:bg-slate-200 text-slate-600 p-2 rounded-full cursor-pointer text-xs z-10"
          title="Editar"
        >
          ✏️
        </button>

        <a href={`${baseUrl}${item.id}`} class="w-full h-full flex flex-col items-center justify-center no-underline text-inherit">
          <div class="text-4xl mb-2 bg-slate-50 p-3.5 rounded-2xl group-hover:bg-slate-100 transition-colors">
            {icons[type]}
          </div>
          
          <div class="font-bold text-slate-800 tracking-tight text-sm sm:text-base line-clamp-2 px-2">
            {item.name}
          </div>

          <!-- Tipo/Categoría de espacio si existe -->
          {item.type && (
            <div class="text-[10px] font-mono uppercase tracking-wider bg-slate-100 text-slate-500 px-2 py-0.5 rounded-md mt-1 border border-slate-200">
              {item.type}
            </div>
          )}

          <!-- BADGE DE RESPONSABLE -->
          {responsible && (
            <div class="mt-2.5 flex items-center gap-1.5 text-[11px] font-medium text-slate-600 bg-slate-50 border border-slate-200/80 px-2.5 py-1 rounded-full max-w-[90%] truncate">
              <span class="text-xs">👤</span>
              <span class="truncate">{responsible}</span>
            </div>
          )}
        </a>
      </div>
    );
  })}
</div>