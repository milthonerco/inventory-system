---
// src/components/modals/QRScannerModal.astro
---

<div id="qrScannerModal" class="hidden fixed inset-0 bg-slate-950/50 backdrop-blur-xs flex items-center justify-center z-50 p-4">
  <div class="bg-white rounded-2xl shadow-xl border border-slate-200 max-w-md w-full p-6 space-y-4">
    
    <div class="flex justify-between items-center border-b pb-3 border-slate-100">
      <div class="flex items-center gap-2">
        <span class="p-2 bg-indigo-50 text-indigo-600 rounded-xl font-bold text-sm">🔍</span>
        <h3 class="font-bold text-slate-800 text-base">Escanear Activo Físico</h3>
      </div>
      <button onclick="closeQRScanner()" class="text-slate-400 hover:text-slate-600 text-xl font-bold cursor-pointer">&times;</button>
    </div>

    <!-- VISTA 1: LECTOR DE CÁMARA -->
    <div id="scannerContainer" class="space-y-3">
      <div id="reader" class="overflow-hidden rounded-xl border-2 border-dashed border-indigo-200 bg-slate-50 min-h-[250px]"></div>
      <p class="text-[11px] text-center text-slate-400 font-medium">Apunta con la cámara al código QR impreso en el activo.</p>
    </div>

    <!-- VISTA 2: RESULTADO DEL ESCANEO (FICHA DEL PRODUCTO Y UBICACIÓN) -->
    <div id="scannerResult" class="hidden space-y-4">
      <div class="p-4 bg-slate-50 rounded-xl border border-slate-200 space-y-3">
        
        <div>
          <span class="text-[10px] font-extrabold uppercase text-indigo-600 bg-indigo-50 border border-indigo-100 px-2 py-0.5 rounded-md" id="resCategory">Categoría</span>
          <h4 class="text-base font-bold text-slate-900 mt-1" id="resName">Nombre del Activo</h4>
          <p class="text-xs text-slate-500 font-mono" id="resSku">SKU: ---</p>
        </div>

        <!-- Jerarquía de Ubicación -->
        <div class="bg-white p-3 rounded-lg border border-slate-200 space-y-1.5 text-xs">
          <p class="font-bold text-slate-700 text-[11px] uppercase tracking-wider">Ubicación Asignada:</p>
          <div class="flex items-center gap-1.5 text-slate-600">
            <span>🏢</span> <strong class="text-slate-800">Sede:</strong> <span id="resCampus">---</span>
          </div>
          <div class="flex items-center gap-1.5 text-slate-600">
            <span>🗺️</span> <strong class="text-slate-800">Zona:</strong> <span id="resZone">---</span>
          </div>
          <div class="flex items-center gap-1.5 text-slate-600">
            <span>📍</span> <strong class="text-slate-800">Lugar Físico:</strong> <span id="resSpace" class="font-bold text-indigo-600">---</span>
          </div>
        </div>

        <div class="flex justify-between items-center text-xs pt-1">
          <span class="text-slate-500">Stock en sistema:</span>
          <span id="resStock" class="font-bold px-2 py-0.5 rounded-md bg-emerald-50 text-emerald-700 border border-emerald-100">0 unidades</span>
        </div>

      </div>

      <!-- Acciones tras escanear -->
      <div class="flex gap-2">
        <button 
          onclick="resetScanner()" 
          class="w-1/2 bg-slate-100 hover:bg-slate-200 text-slate-700 py-2.5 rounded-xl text-xs font-semibold cursor-pointer transition-all"
        >
          🔄 Escanear Otro
        </button>
        <button 
          onclick="closeQRScanner()" 
          class="w-1/2 bg-indigo-600 hover:bg-indigo-700 text-white py-2.5 rounded-xl text-xs font-bold cursor-pointer transition-all shadow-xs"
        >
          Listo
        </button>
      </div>
    </div>

  </div>
</div>

<script>
  import { Html5Qrcode } from "html5-qrcode";

  let html5QrcodeScanner: Html5Qrcode | null = null;

  (window as any).openQRScanner = async () => {
    document.getElementById('qrScannerModal')?.classList.remove('hidden');
    document.getElementById('scannerContainer')?.classList.remove('hidden');
    document.getElementById('scannerResult')?.classList.add('hidden');

    try {
      html5QrcodeScanner = new Html5Qrcode("reader");
      await html5QrcodeScanner.start(
        { facingMode: "environment" },
        { fps: 10, qrbox: { width: 200, height: 200 } },
        onScanSuccess,
        () => {}
      );
    } catch (err) {
      console.error("Error al abrir cámara:", err);
      alert("No se pudo acceder a la cámara. Revisa los permisos de tu navegador.");
    }
  };

  async function onScanSuccess(decodedText: string) {
    console.log("🔍 Texto bruto escaneado desde el QR:", decodedText);

    if (html5QrcodeScanner) {
      await html5QrcodeScanner.stop();
    }

    // 🛠️ SANITIZACIÓN DEL CÓDIGO QR
    let cleanId = decodedText.trim();

    // Caso A: Si el QR fue generado como "PRODUCT:uuid" o "ID:uuid"
    if (cleanId.includes(':')) {
      cleanId = cleanId.split(':').pop() || cleanId;
    }

    // Caso B: Si el QR fue generado como una URL "https://.../product?id=uuid" o "...?product=uuid"
    if (cleanId.includes('?')) {
      const urlParams = new URLSearchParams(cleanId.split('?')[1]);
      cleanId = urlParams.get('product') || urlParams.get('id') || cleanId;
    }

    console.log("✅ ID limpio para consultar en Supabase:", cleanId);

    fetchProductDetails(cleanId);
  }

  async function fetchProductDetails(productId: string) {
    try {
      const response = await fetch(`/api/inventory/products/${productId}`);
      
      if (!response.ok) {
        throw new Error(`Estado ${response.status}: Producto no encontrado`);
      }

      const data = await response.json();

      // Mapeo adaptado a la tabla "physical_spaces"
      (document.getElementById('resName') as HTMLElement).innerText = data.name || 'Sin Nombre';
      (document.getElementById('resSku') as HTMLElement).innerText = `SKU: ${data.sku || 'N/A'}`;
      (document.getElementById('resCategory') as HTMLElement).innerText = data.categories?.name || 'General';
      
      // Jerarquía física real
      const space = data.physical_spaces;
      const zone = space?.zones;
      const campus = zone?.campuses;

      (document.getElementById('resCampus') as HTMLElement).innerText = campus?.name || 'No asignado';
      (document.getElementById('resZone') as HTMLElement).innerText = zone?.name || 'No asignada';
      (document.getElementById('resSpace') as HTMLElement).innerText = space ? `${space.name} (${space.type || 'Espacio'})` : 'No asignado';
      (document.getElementById('resStock') as HTMLElement).innerText = `${data.stock ?? 0} unidades`;

      // Ocultar cámara y mostrar resultados
      document.getElementById('scannerContainer')?.classList.add('hidden');
      document.getElementById('scannerResult')?.classList.remove('hidden');

    } catch (error) {
      console.error("Error en API:", error);
      alert(`⚠️ No se encontró ningún activo en la base de datos con el ID: [${productId}]`);
      (window as any).resetScanner();
    }
  }

  (window as any).resetScanner = () => {
    (window as any).openQRScanner();
  };

  (window as any).closeQRScanner = async () => {
    if (html5QrcodeScanner && html5QrcodeScanner.isScanning) {
      await html5QrcodeScanner.stop();
    }
    document.getElementById('qrScannerModal')?.classList.add('hidden');
  };
</script>