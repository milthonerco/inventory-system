---
// src/components/SuperAdminMovements.astro
interface Props {
  movements: any[];
  campuses: any[];
  zones: any[];
}

const { movements = [], campuses = [], zones = [] } = Astro.props;
---

<div class="space-y-6 bg-white border border-slate-200 p-6 rounded-2xl shadow-xs">
  <!-- Cabecera de la Sección -->
  <div class="flex flex-wrap justify-between items-center gap-4 border-b border-slate-100 pb-4">
    <div>
      <h2 class="text-lg font-bold text-slate-900 tracking-tight flex items-center gap-2">
        <span>📊</span> Bitácora Global de Movimientos (Super Admin)
      </h2>
      <p class="text-xs text-slate-400">Historial completo de entradas, salidas y modificaciones de inventario en toda la organización.</p>
    </div>
  </div>

  <!-- Barra de Filtros Dinámicos -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 bg-slate-50 p-4 rounded-xl border border-slate-100">
    <div>
      <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Filtrar por Sede:</label>
      <select id="globalCampusFilter" class="w-full border border-slate-200 rounded-xl p-2 text-xs bg-white outline-none font-semibold text-slate-700">
        <option value="all">Todas las Sedes</option>
        {campuses.map(c => <option value={c.name}>{c.name}</option>)}
      </select>
    </div>

    <div>
      <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1">Filtrar por Zona:</label>
      <select id="globalZoneFilter" class="w-full border border-slate-200 rounded-xl p-2 text-xs bg-white outline-none font-semibold text-slate-700">
        <option value="all">Todas las Zonas</option>
        {zones.map(z => <option value={z.name}>{z.name}</option>)}
      </select>
    </div>

    <div>
      <label class="block text-[10px] font-bold text-slate-400 uppercase mb-1 font-mono">Buscar Lugar Físico:</label>
      <input 
        type="text" 
        id="globalSpaceFilter" 
        placeholder="Ej: Bodega B..." 
        class="w-full border border-slate-200 rounded-xl p-2 text-xs bg-white outline-none font-medium text-slate-700 placeholder:text-slate-300"
      />
    </div>
  </div>

  <!-- Tabla de Auditoría -->
  <div class="border border-slate-200 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse text-xs" id="globalMovementsTable">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200 text-[10px] font-bold text-slate-400 uppercase tracking-wider">
            <th class="p-4">Ubicación (Sede / Zona / Lugar)</th>
            <th class="p-4">Producto</th>
            <th class="p-4">Transacción</th>
            <th class="p-4 text-center">Cantidad</th>
            <th class="p-4">Fecha y Hora</th>
            <th class="p-4">Responsable</th>
            <th class="p-4">Concepto / Motivo</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 font-medium text-slate-600">
          {movements.length === 0 ? (
            <tr class="no-global-movements">
              <td colspan="7" class="p-8 text-center text-slate-400">No se han registrado movimientos en el sistema aún.</td>
            </tr>
          ) : (
            movements.map((mov) => (
              <tr 
                class="global-movement-row hover:bg-slate-50/50 transition-colors"
                data-campus={mov.campus_name || 'N/A'}
                data-zone={mov.zone_name || 'N/A'}
                data-space={mov.space_name || 'N/A'}
              >
                <!-- Ubicación jerárquica -->
                <td class="p-4 space-y-0.5">
                  <p class="font-bold text-slate-800 text-[11px]">{mov.space_name || 'N/A'}</p>
                  <p class="text-slate-400 text-[10px] uppercase tracking-wide">
                    {mov.campus_name || 'N/A'} • {mov.zone_name || 'N/A'}
                  </p>
                </td>

                <!-- Producto -->
                <td class="p-4 font-bold text-indigo-700">{mov.product_name}</td>

                <!-- Tipo -->
                <td class="p-4">
                  {mov.type === 'entry' || mov.type === 'input' ? (
                    <span class="inline-flex items-center gap-1 bg-emerald-50 text-emerald-700 text-[10px] font-extrabold px-2 py-0.5 rounded-lg border border-emerald-100">
                      ⬇️ Entrada
                    </span>
                  ) : (
                    <span class="inline-flex items-center gap-1 bg-rose-50 text-rose-700 text-[10px] font-extrabold px-2 py-0.5 rounded-lg border border-rose-100">
                      ⬆️ Salida / Baja
                    </span>
                  )}
                </td>

                <!-- Cantidad -->
                <td class="p-4 text-center font-bold text-slate-800 text-sm">{mov.quantity}</td>

                <!-- Fecha -->
                <td class="p-4 text-slate-400">
                  {new Date(mov.created_at).toLocaleString('es-ES', { 
                    dateStyle: 'short', 
                    timeStyle: 'short' 
                  })}
                </td>

                <!-- Responsable -->
                <td class="p-4 font-semibold text-slate-700">{mov.user_email || 'Sistema'}</td>

                <!-- Motivo -->
                <td class="p-4 italic text-slate-400 max-w-xs truncate" title={mov.reason || mov.concept}>
                  {mov.reason || mov.concept || 'Sin detalles'}
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>
  </div>
</div>

<script is:inline>
  // Lógica de filtrado dinámico multi-criterio en cliente
  const campusSelect = document.getElementById('globalCampusFilter');
  const zoneSelect = document.getElementById('globalZoneFilter');
  const spaceInput = document.getElementById('globalSpaceFilter');

  function applyGlobalFilters() {
    const selectedCampus = campusSelect.value;
    const selectedZone = zoneSelect.value;
    const searchSpace = spaceInput.value.toLowerCase().trim();

    const rows = document.querySelectorAll('.global-movement-row');
    let matches = 0;

    rows.forEach(row => {
      const campus = row.getAttribute('data-campus');
      const zone = row.getAttribute('data-zone');
      const space = row.getAttribute('data-space').toLowerCase();

      const matchesCampus = selectedCampus === 'all' || campus === selectedCampus;
      const matchesZone = selectedZone === 'all' || zone === selectedZone;
      const matchesSpace = !searchSpace || space.includes(searchSpace);

      if (matchesCampus && matchesZone && matchesSpace) {
        row.classList.remove('hidden');
        matches++;
      } else {
        row.classList.add('hidden');
      }
    });

    // Gestionar fila de "Sin resultados"
    const existingNoResults = document.querySelector('.no-global-results-row');
    if (matches === 0) {
      if (!existingNoResults) {
        const tbody = document.querySelector('#globalMovementsTable tbody');
        const tr = document.createElement('tr');
        tr.className = 'no-global-results-row';
        tr.innerHTML = `<td colspan="7" class="p-8 text-center text-slate-400 font-medium">No se encontraron movimientos que coincidan con los filtros seleccionados.</td>`;
        tbody.appendChild(tr);
      }
    } else {
      existingNoResults?.remove();
    }
  }

  campusSelect?.addEventListener('change', applyGlobalFilters);
  zoneSelect?.addEventListener('change', applyGlobalFilters);
  spaceInput?.addEventListener('input', applyGlobalFilters);
</script>