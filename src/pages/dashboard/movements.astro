---
// src/pages/dashboard/movements.astro
import { MovementsService } from "../../services/movements.service";
import "../../styles/global.css";

// Control de Sesión y Autenticación
const { user, role } = Astro.locals;
const userEmail = user?.email || "usuario@correo.com";

// Si no es super_admin, redirigir al dashboard principal
if (role !== 'super_admin') {
  return Astro.redirect('/dashboard');
}

// Carga global de movimientos usando nuestro servicio
let movements: any[] = [];
let errorMsg = "";

try {
  movements = await MovementsService.getAllMovementsForAdmin();
} catch (e: any) {
  errorMsg = e.message;
}

// Extraer listas únicas para los selectores de filtros dinámicos
const uniqueCampuses = Array.from(new Set(movements.map(m => JSON.stringify({ id: m.campus_id, name: m.campus_name })))).map(s => JSON.parse(s)).filter(c => c.id !== null);
const uniqueZones = Array.from(new Set(movements.map(m => JSON.stringify({ id: m.zone_id, name: m.zone_name, campus_id: m.campus_id })))).map(s => JSON.parse(s)).filter(z => z.id !== null);
const uniqueSpaces = Array.from(new Set(movements.map(m => JSON.stringify({ id: m.space_id, name: m.space_name, zone_id: m.zone_id })))).map(s => JSON.parse(s)).filter(sp => sp.id !== null);
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Historial Global de Movimientos | Bitácora</title>
  </head>
  <body class="bg-slate-50 min-h-screen font-sans antialiased text-slate-900">
    
    <!-- HEADER -->
    <header class="fixed top-0 left-0 right-0 h-16 bg-white border-b border-slate-200 z-40 px-4 lg:px-8 flex items-center justify-between shadow-xs">
      <div class="flex items-center gap-2">
        <span class="text-xl font-bold">📊</span>
        <h1 class="text-lg font-bold text-indigo-700 tracking-tight">Historial Global de Inventario</h1>
      </div>
      <div class="flex items-center gap-4">
        <a href="/dashboard" class="bg-indigo-50 hover:bg-indigo-100 text-indigo-700 border border-indigo-200 text-xs font-bold px-4 py-2 rounded-xl transition-all cursor-pointer">
          Volver al Panel
        </a>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 lg:px-8 pt-24 pb-12 space-y-6">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div>
          <h2 class="text-2xl font-black text-slate-900 tracking-tight">Bitácora General de Stock</h2>
          <p class="text-xs text-slate-500">Monitoreo absoluto sobre entradas, salidas y auditorías en todos los campuses.</p>
        </div>
      </div>

      <!-- FILTROS DINÁMICOS -->
      <section class="bg-white p-5 border border-slate-200 rounded-2xl shadow-xs grid grid-cols-1 md:grid-cols-4 gap-4">
        <div>
          <label class="block text-xs font-semibold text-slate-500 mb-1.5">Campus / Sede</label>
          <select id="filterCampus" class="w-full bg-slate-50 border border-slate-200 text-xs px-3 py-2 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all" onchange="applyFilters()">
            <option value="">Todos los campuses</option>
            {uniqueCampuses.map(c => (
              <option value={c.id}>{c.name}</option>
            ))}
          </select>
        </div>

        <div>
          <label class="block text-xs font-semibold text-slate-500 mb-1.5">Zona</label>
          <select id="filterZone" class="w-full bg-slate-50 border border-slate-200 text-xs px-3 py-2 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all" onchange="applyFilters()">
            <option value="">Todas las zonas</option>
            {uniqueZones.map(z => (
              <option value={z.id} data-campus={z.campus_id}>{z.name}</option>
            ))}
          </select>
        </div>

        <div>
          <label class="block text-xs font-semibold text-slate-500 mb-1.5">Espacio Físico</label>
          <select id="filterSpace" class="w-full bg-slate-50 border border-slate-200 text-xs px-3 py-2 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all" onchange="applyFilters()">
            <option value="">Todos los espacios</option>
            {uniqueSpaces.map(s => (
              <option value={s.id} data-zone={s.zone_id}>{s.name}</option>
            ))}
          </select>
        </div>

        <div>
          <label class="block text-xs font-semibold text-slate-500 mb-1.5">Tipo de Cambio</label>
          <select id="filterType" class="w-full bg-slate-50 border border-slate-200 text-xs px-3 py-2 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all" onchange="applyFilters()">
            <option value="">Todos los movimientos</option>
            <option value="input">Entrada (Input)</option>
            <option value="output">Salida (Output)</option>
          </select>
        </div>
      </section>

      {errorMsg && (
        <div class="bg-red-50 text-red-700 p-4 rounded-2xl text-xs font-bold border border-red-200">
          ⚠️ {errorMsg}
        </div>
      )}

      <!-- TABLA DE MOVIMIENTOS -->
      <section class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-xs">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-100 text-[11px] font-bold text-slate-400 uppercase tracking-wider">
                <th class="py-3 px-4">Producto</th>
                <th class="py-3 px-4">Tipo</th>
                <th class="py-3 px-4 text-center">Cantidad</th>
                <th class="py-3 px-4">Sede / Zona / Lugar</th>
                <th class="py-3 px-4">Fecha</th>
                <th class="py-3 px-4">Responsable</th>
                <th class="py-3 px-4">Motivo</th>
              </tr>
            </thead>
            <tbody id="movementsTableBody" class="divide-y divide-slate-100 text-xs font-medium text-slate-600">
              {movements.map(mov => (
                <tr 
                  class="hover:bg-slate-50/50 transition-colors movement-row"
                  data-campus-id={mov.campus_id}
                  data-zone-id={mov.zone_id}
                  data-space-id={mov.space_id}
                  data-type={mov.type}
                >
                  <td class="py-3 px-4 font-bold text-slate-800">{mov.product_name}</td>
                  <td class="py-3 px-4">
                    {mov.type === 'input' ? (
                      <span class="inline-flex items-center gap-1 bg-green-50 text-green-700 text-[10px] font-extrabold px-2 py-1 rounded-lg">
                        ⬇️ Entrada
                      </span>
                    ) : (
                      <span class="inline-flex items-center gap-1 bg-rose-50 text-rose-700 text-[10px] font-extrabold px-2 py-1 rounded-lg">
                        ⬆️ Salida
                      </span>
                    )}
                  </td>
                  <td class="py-3 px-4 text-center font-bold text-slate-700">{mov.quantity}</td>
                  <td class="py-3 px-4">
                    <div class="text-slate-700 font-bold">{mov.space_name}</div>
                    <div class="text-[10px] text-slate-400">{mov.campus_name} • {mov.zone_name}</div>
                  </td>
                  <td class="py-3 px-4 text-slate-400">
                    {new Date(mov.created_at).toLocaleString('es-ES', { dateStyle: 'short', timeStyle: 'short' })}
                  </td>
                  <td class="py-3 px-4 font-semibold text-slate-700">{mov.user_email}</td>
                  <td class="py-3 px-4 italic text-slate-400 max-w-xs truncate" title={mov.reason}>{mov.reason}</td>
                </tr>
              ))}
              {movements.length === 0 && (
                <tr>
                  <td colspan="7" class="py-8 text-center text-slate-400">No se han registrado movimientos de inventario aún.</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </section>
    </main>

    <script is:inline>
      function applyFilters() {
        const campusVal = document.getElementById('filterCampus').value;
        const zoneVal = document.getElementById('filterZone').value;
        const spaceVal = document.getElementById('filterSpace').value;
        const typeVal = document.getElementById('filterType').value;

        const rows = document.querySelectorAll('.movement-row');

        rows.forEach(row => {
          const rowCampus = row.getAttribute('data-campus-id');
          const rowZone = row.getAttribute('data-zone-id');
          const rowSpace = row.getAttribute('data-space-id');
          const rowType = row.getAttribute('data-type');

          let matchesCampus = !campusVal || rowCampus === campusVal;
          let matchesZone = !zoneVal || rowZone === zoneVal;
          let matchesSpace = !spaceVal || rowSpace === spaceVal;
          let matchesType = !typeVal || rowType === typeVal;

          if (matchesCampus && matchesZone && matchesSpace && matchesType) {
            row.classList.remove('hidden');
          } else {
            row.classList.add('hidden');
          }
        });

        // Filtrado en cascada visual para las zonas y espacios en los selectores
        const zoneOptions = document.querySelectorAll('#filterZone option');
        zoneOptions.forEach(opt => {
          if (!opt.value) return;
          const campusId = opt.getAttribute('data-campus');
          if (!campusVal || campusId === campusVal) {
            opt.classList.remove('hidden');
          } else {
            opt.classList.add('hidden');
          }
        });

        const spaceOptions = document.querySelectorAll('#filterSpace option');
        spaceOptions.forEach(opt => {
          if (!opt.value) return;
          const zoneId = opt.getAttribute('data-zone');
          if (!zoneVal || zoneId === zoneVal) {
            opt.classList.remove('hidden');
          } else {
            opt.classList.add('hidden');
          }
        });
      }
    </script>
  </body>
</html>