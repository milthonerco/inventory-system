---
// src/pages/force-change-password.astro
import "../styles/global.css";
---
<html lang="es">
<head>
  <meta charset="utf-8" />
  <title>Actualización de Contraseña Obligatoria</title>
</head>
<body class="bg-slate-50 flex items-center justify-center min-h-screen p-4">
  <div class="bg-white p-8 rounded-2xl shadow-xl border max-w-md w-full space-y-6">
    <div class="space-y-2 text-center">
      <h1 class="text-2xl font-bold text-slate-900">Primer Inicio de Sesión</h1>
      <p class="text-sm text-slate-500">Por seguridad, debes cambiar la contraseña temporal asignada antes de ingresar al sistema.</p>
    </div>

    <form id="forceResetForm" class="space-y-4">
      <div>
        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Nueva Contraseña</label>
        <input type="password" id="password" required minlength="6" placeholder="Mínimo 6 caracteres" class="w-full border rounded-xl p-3 text-sm outline-none focus:border-blue-600" />
      </div>

      <div>
        <label class="block text-xs font-bold text-slate-500 uppercase mb-1">Confirmar Contraseña</label>
        <input type="password" id="confirmPassword" required minlength="6" placeholder="Repite la contraseña" class="w-full border rounded-xl p-3 text-sm outline-none focus:border-blue-600" />
      </div>
      
      <div id="message" class="hidden text-sm p-3 rounded-xl"></div>

      <button type="submit" id="submitBtn" class="w-full bg-blue-600 text-white py-3 rounded-xl text-sm font-semibold cursor-pointer hover:bg-blue-700 transition">
        Actualizar y Comenzar
      </button>
    </form>
  </div>

  <script>
    const form = document.getElementById('forceResetForm') as HTMLFormElement;
    const messageDiv = document.getElementById('message') as HTMLDivElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const password = (document.getElementById('password') as HTMLInputElement).value;
      const confirmPassword = (document.getElementById('confirmPassword') as HTMLInputElement).value;

      messageDiv.classList.add('hidden');

      if (password !== confirmPassword) {
        messageDiv.className = 'text-sm p-3 rounded-xl bg-rose-50 text-rose-700 border border-rose-200';
        messageDiv.innerText = 'Las contraseñas no coinciden.';
        messageDiv.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.innerText = 'Guardando...';

      try {
        // Hacemos la petición a nuestra API en el servidor
        const response = await fetch('/api/auth/change-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password })
        });

        const data = await response.json();

        if (response.ok) {
          messageDiv.className = 'text-sm p-3 rounded-xl bg-green-50 text-green-700 border border-green-200';
          messageDiv.innerText = 'Contraseña actualizada con éxito. Redirigiendo...';
          messageDiv.classList.remove('hidden');

          setTimeout(() => {
            window.location.href = '/';
          }, 2000);
        } else {
          throw new Error(data.message || 'Error al actualizar');
        }

      } catch (err: any) {
        messageDiv.className = 'text-sm p-3 rounded-xl bg-rose-50 text-rose-700 border border-rose-200';
        messageDiv.innerText = `Error: ${err.message || 'No se pudo actualizar'}`;
        messageDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.innerText = 'Actualizar y Comenzar';
      }
    });
  </script>
</body>
</html>